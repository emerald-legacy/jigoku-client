{
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "sourceMap": true,
    "outDir": "build",
    "rootDir": ".",
    "allowJs": false,
    "strict": false,
    "lib": ["ES2022"],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleDetection": "force"
  },
  "include": [
    "server/**/*",
    "shared/**/*",
    "index.ts",
    "client/deck-validator.ts"
  ],
  "exclude": [
    "node_modules",
    "test/**/*",
    "build/**/*"
  ]
}
