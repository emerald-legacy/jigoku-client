{
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "es2022",
    "sourceMap": true,
    "outDir": "build",
    "rootDir": ".",
    "allowJs": true,
    "strict": false,
    "lib": [
      "es2022"
    ],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleDetection": "force"
  },
  "include": [
    "server/**/*",
    "index.ts",
    "version.js",
    "client/GameModes.ts",
    "client/deck-validator.ts"
  ],
  "exclude": [
    "node_modules",
    "test/**/*",
    "build/**/*"
  ]
}
