{
    env: 'development',

    secret: 'somethingverysecret',
    dbPath: 'mongodb://127.0.0.1:27017/jigoku',
    lobbyWsUrl: 'ws://127.0.0.1:6000',

    // Additional CSP connect-src hosts (for game nodes, external APIs, etc.)
    // In production, add your game node URLs here, e.g.: ['https://node1.example.com', 'wss://node1.example.com']
    cspConnectSources: ['http://localhost:9501', 'http://localhost:9502', 'ws://localhost:9501', 'ws://localhost:9502'],

    /*
     * Other global configurations used, but not specified, include:
     *  - sentryDsn (for production only)
     */

    lobby: {
        port: 4000

        /*
         * Other server configurations used, but not specified, include:
         *  - cookieLifetime
         *  - emailPath
         *  - hmacSecret
         *  - captchaKey
         */
    },

    gameNode: {
        name: 'test1',
        host: 'localhost',
        socketioPort: 9500

        /*
         * Other game node configurations used, but not specified, include:
         *  - keyPath
         *  - certPath
         *  - maxGames
         */
    }
}
